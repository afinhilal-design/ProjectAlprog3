<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ProjectAlprog3.HistoryPage"
             BackgroundColor="#0A0E1A">
    <VerticalStackLayout Padding="24" Spacing="14">
        <Label Text="📋 Riwayat Pemeriksaan" FontSize="26" FontAttributes="Bold" TextColor="#E2E8F0" />
        <CollectionView x:Name="HistoryCollection">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame BackgroundColor="#1A2238" CornerRadius="14" Margin="0,6">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="{Binding Time}" TextColor="#94A3B8" />
                            <Label Text="{Binding Result.EstimatedGlucose, StringFormat='Glukosa: {0:F0} mg/dL'}" FontAttributes="Bold" TextColor="#60A5FA" />
                            <Label Text="{Binding Result.FinalRisk, StringFormat='Risiko Akhir: {0}'}" TextColor="#F59E0B" />
                            <Label Text="{Binding Result.Recommendation}" TextColor="#CBD5E1" />
                        </VerticalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
        <Button Text="← Dashboard" BackgroundColor="Transparent" TextColor="#60A5FA" Clicked="OnBackClicked" />
    </VerticalStackLayout>
</ContentPage>

